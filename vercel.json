{
  "rewrites": [{ "source": "/((?!api/).*)", "destination": "/" }],
  "headers": [{
    "source": "/(.*)",
    "headers": [
      { "key": "X-Frame-Options", "value": "ALLOWALL" },
      { "key": "Content-Security-Policy", "value": "frame-ancestors *" }
    ]
  }],
  "crons": [
    {
      "path": "/api/remind",
      "schedule": "0 10 * * *"
    }
  ]
}
