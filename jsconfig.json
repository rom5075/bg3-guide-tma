{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": false,
    "noEmit": true,
    "allowImportingTsExtensions": false,
    "checkJs": false,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": []
  },
  "include": [
    "src/**/*",
    "api/**/*",
    "bot/**/*",
    "server.js",
    "vite.config.js"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "data"
  ]
}
